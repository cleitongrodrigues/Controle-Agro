// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // Connection URL is configured in prisma.config.ts via DATABASE_URL
}

// Use DATABASE_URL in your environment, e.g.:
// DATABASE_URL="postgresql://user:password@host:5432/dbname"


enum FarmStatus {
  visitado
  pendente
  urgente
}

enum ProductCategory {
  herbicida
  semente
  fertilizante
  fungicida
  outro
}

enum DescontoTipo {
  percentual
  valor
}

model Fazenda {
  id           String   @id @default(uuid())
  nome         String
  proprietario String
  hectares     Float
  localizacao  String
  telefone     String?
  status       FarmStatus
  latitude     Float?
  longitude    Float?
  vendas       Venda[]
  @@map("fazendas")
}

model Venda {
  id               String     @id @default(uuid())
  fazendaId        String
  fazenda          Fazenda    @relation(fields: [fazendaId], references: [id])
  produto          String
  quantidade       Int
  valorUnitario    Float
  valorTotal       Float
  desconto         Float?
  descontoTipo     DescontoTipo?
  valorComDesconto Float?
  data             DateTime
  sincronizado     Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  @@map("vendas")
}

model Produto {
  id        String          @id @default(uuid())
  nome      String
  preco     Float
  categoria ProductCategory
  @@map("produtos")
}

model Meta {
  id        String   @id @default(uuid())
  nome      String
  valorMeta Float
  categoria String?
  ativo     Boolean  @default(true)
  @@map("metas")
}

model Cliente {
  id       String @id @default(uuid())
  iniciais String
  nome     String
  detalhe  String
  status   String // 'ativo' | 'sem-compra' | 'pendente'
  @@map("clientes")
}

model Comissao {
  id            String  @id @default(uuid())
  percentual    Float
  valorBase     Float
  valorComissao Float
  mes           String
  @@map("comissoes")
}
